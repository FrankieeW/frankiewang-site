---
import ProjectCard from "../../../components/ProjectCard.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getLocale, locales, projectCategories, site } from "../../../data/site";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = getLocale(Astro.params.lang);
const content = site[locale];

const groups = projectCategories
  .map((category) => ({
    category,
    label: content.projectCategoryLabels[category],
    items: content.projects.filter((project) => project.category === category),
  }))
  .filter((group) => group.items.length > 0);
---

<BaseLayout
  locale={locale}
  title={content.projectsPage.title}
  description={content.projectsPage.description}
>
  <section>
    <h1>{content.projectsPage.heading}</h1>
    <p class="muted">{content.projectsPage.lead}</p>
  </section>

  {groups.map((group) => (
    <section>
      <h2>{group.label}</h2>
      <div class="grid three project-grid">
        {group.items.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>
  ))}
</BaseLayout>

<style>
  .project-grid {
    margin-top: 1rem;
  }
</style>
