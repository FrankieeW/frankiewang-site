---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getLocale, localePath, locales, site } from "../../../data/site";

export function getStaticPaths() {
  return locales.flatMap((lang) =>
    site[lang].products.map((product) => ({
      params: { lang, slug: product.slug },
      props: { product },
    })),
  );
}

const locale = getLocale(Astro.params.lang);
const content = site[locale];
const { product } = Astro.props;
---

<BaseLayout locale={locale} title={product.name} description={product.tagline}>
  <article>
    <section>
      <p class="back">
        <a href={localePath(locale, "products/")}>← {content.productsPage.title}</a>
      </p>
      <h1>{product.name}</h1>
      <p class="role muted">{product.eyebrow} · {content.productLabels.status}: {product.status}</p>
      <p class="lead">{product.tagline}</p>
    </section>

    <section>
      <h2>{content.productLabels.audience}</h2>
      <p>{product.audience}</p>

      <h2>{content.productLabels.problem}</h2>
      <p>{product.problem}</p>

      <h2>{content.productLabels.solution}</h2>
      <p>{product.solution}</p>

      <h2>{content.productLabels.features}</h2>
      <ul class="feature-list">
        {product.features.map((feature) => <li>{feature}</li>)}
      </ul>
    </section>
  </article>
</BaseLayout>

<style>
  .back {
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .role {
    margin-bottom: 1rem;
  }

  .feature-list {
    margin: 0;
    padding-left: 1.25rem;
  }

  .feature-list li {
    margin-bottom: 0.25rem;
  }
</style>
