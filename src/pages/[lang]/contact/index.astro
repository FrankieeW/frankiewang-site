---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getLocale, locales, site } from "../../../data/site";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = getLocale(Astro.params.lang);
const content = site[locale];
const { profile } = content;

const githubHandle = (url: string) => url.replace("https://github.com/", "@");
---

<BaseLayout
  locale={locale}
  title={content.contactPage.title}
  description={content.contactPage.description}
>
  <section>
    <h1>{content.contactPage.heading}</h1>
    <p class="muted">{content.contactPage.lead}</p>
    <ul class="contact-list">
      <li>Email · <a href={`mailto:${profile.email}`}>{profile.email}</a></li>
      <li>
        GitHub ·
        <a href={profile.github}>{githubHandle(profile.github)}</a>
        <span class="muted">({content.sections.contact.githubMain})</span>
        ·
        <a href={profile.githubAcademic}>{githubHandle(profile.githubAcademic)}</a>
        <span class="muted">({content.sections.contact.githubAcademic})</span>
      </li>
    </ul>
  </section>

  <section>
    <h2>{content.contactPage.socialsTitle}</h2>
    <p class="muted todo">{content.contactPage.socialPlaceholder}</p>
  </section>
</BaseLayout>

<style>
  .contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .contact-list li {
    margin-bottom: 0.35rem;
  }

  .todo {
    font-style: italic;
    margin: 0;
  }
</style>
