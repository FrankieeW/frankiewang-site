---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getLocale, locales, site } from "../../../data/site";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

type EducationTrack = {
  school: string;
  programme: string;
  result: string;
};

type EducationItem = {
  period: string;
  degree: string;
  institution: string;
  note?: string;
  courses?: readonly string[];
  tracks?: readonly EducationTrack[];
};

const locale = getLocale(Astro.params.lang);
const content = site[locale];
const education = content.education as readonly EducationItem[];
---

<BaseLayout
  locale={locale}
  title={content.academicPage.title}
  description={content.academicPage.description}
>
  <section>
    <h1>{content.academicPage.heading}</h1>
    <p class="muted">{content.academicPage.lead}</p>
  </section>

  <section>
    <h2>{content.sections.academic.interestsTitle}</h2>
    <ul class="topic-list">
      {content.researchInterests.map((item) => (
        <li><strong>{item.title}.</strong> {item.text}</li>
      ))}
    </ul>
  </section>

  <section>
    <h2>{content.sections.academic.educationTitle}</h2>
    <ol class="education-list">
      {education.map((item) => (
        <li class="edu-entry">
          <div class="edu-period">
            <span>{item.period}</span>
          </div>
          <div class="edu-body">
            <h3 class="edu-degree">{item.degree}</h3>
            <p class="edu-institution">{item.institution}</p>
            {item.note && <p class="edu-note muted">{item.note}</p>}

            {item.tracks && (
              <ul class="track-list">
                {item.tracks.map((track) => (
                  <li class="track">
                    <p class="track-school">{track.school}</p>
                    <p class="track-meta">
                      <span>{track.programme}</span>
                      <span class="track-result">{track.result}</span>
                    </p>
                  </li>
                ))}
              </ul>
            )}

            {item.courses && (
              <details class="courses">
                <summary>
                  <span class="courses-label">{content.sections.academic.currentCoursesTitle}</span>
                  <span class="courses-count">({item.courses.length})</span>
                </summary>
                <ul class="course-list">
                  {item.courses.map((course) => <li>{course}</li>)}
                </ul>
              </details>
            )}
          </div>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>

<style>
  .topic-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .topic-list li {
    margin-bottom: 0.55rem;
  }

  .education-list {
    counter-reset: edu;
    display: grid;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .edu-entry {
    border-top: 1px solid var(--line);
    display: grid;
    gap: 0.4rem 1.6rem;
    grid-template-columns: 7.5rem minmax(0, 1fr);
    padding: 1.5rem 0;
  }

  .edu-entry:first-child {
    border-top: 0;
    padding-top: 0.4rem;
  }

  .edu-entry:last-child {
    padding-bottom: 0.4rem;
  }

  .edu-period {
    color: var(--muted);
    font-feature-settings: "lnum" 1;
    font-size: 0.92rem;
    font-style: italic;
    padding-top: 0.25rem;
  }

  .edu-body {
    min-width: 0;
  }

  .edu-degree {
    font-size: 1.12rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    margin-bottom: 0.25rem;
  }

  .edu-institution {
    color: var(--ink);
    font-size: 0.98rem;
    font-style: italic;
    margin-bottom: 0.35rem;
  }

  .edu-note {
    font-size: 0.92rem;
    margin-bottom: 0;
  }

  .track-list {
    border-left: 2px solid var(--line);
    display: grid;
    gap: 0.7rem;
    list-style: none;
    margin: 0.9rem 0 0;
    padding: 0.15rem 0 0.15rem 0.9rem;
  }

  .track-school {
    font-weight: 600;
    margin-bottom: 0.1rem;
  }

  .track-meta {
    color: var(--muted);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.92rem;
    gap: 0.4rem 1rem;
    justify-content: space-between;
    margin-bottom: 0;
  }

  .track-result {
    color: var(--ink);
    font-feature-settings: "lnum" 1;
    font-style: italic;
  }

  .courses {
    margin-top: 1.1rem;
  }

  .courses > summary {
    align-items: baseline;
    cursor: pointer;
    display: inline-flex;
    gap: 0.4rem;
    list-style: none;
    padding-left: 1.1rem;
    position: relative;
    user-select: none;
  }

  .courses > summary::-webkit-details-marker {
    display: none;
  }

  .courses > summary::before {
    color: var(--muted);
    content: "›";
    font-size: 0.95rem;
    left: 0;
    line-height: 1;
    position: absolute;
    top: 0.25rem;
    transition: transform 0.15s ease;
  }

  .courses[open] > summary::before {
    transform: rotate(90deg);
    transform-origin: 0.18rem 0.45rem;
  }

  .courses > summary:hover .courses-label {
    color: var(--ink);
  }

  .courses-label {
    color: var(--muted);
    font-size: 0.82rem;
    font-style: italic;
    letter-spacing: 0.02em;
  }

  .courses-count {
    color: var(--muted);
    font-feature-settings: "lnum" 1;
    font-size: 0.8rem;
  }

  .course-list {
    column-count: 2;
    column-gap: 1.75rem;
    font-size: 0.94rem;
    list-style: none;
    margin: 0.6rem 0 0;
    padding: 0;
  }

  .course-list li {
    break-inside: avoid;
    padding: 0.12rem 0;
    position: relative;
    padding-left: 0.95rem;
  }

  .course-list li::before {
    color: var(--muted);
    content: "—";
    left: 0;
    position: absolute;
  }

  @media (max-width: 640px) {
    .edu-entry {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .edu-period {
      padding-top: 0;
    }

    .track-meta {
      flex-direction: column;
      gap: 0.1rem;
    }

    .course-list {
      column-count: 1;
    }
  }
</style>
