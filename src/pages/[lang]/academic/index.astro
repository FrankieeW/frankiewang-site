---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getLocale, locales, site } from "../../../data/site";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

type EducationTrack = {
  school: string;
  programme: string;
  result: string;
};

type EducationItem = {
  period: string;
  degree: string;
  institution: string;
  note?: string;
  courses?: readonly string[];
  tracks?: readonly EducationTrack[];
};

const locale = getLocale(Astro.params.lang);
const content = site[locale];
const education = content.education as readonly EducationItem[];
---

<BaseLayout
  locale={locale}
  title={content.academicPage.title}
  description={content.academicPage.description}
>
  <section>
    <h1>{content.academicPage.heading}</h1>
    <p class="muted">{content.academicPage.lead}</p>
  </section>

  <section>
    <h2>{content.sections.academic.interestsTitle}</h2>
    <ul class="topic-list">
      {content.researchInterests.map((item) => (
        <li><strong>{item.title}.</strong> {item.text}</li>
      ))}
    </ul>
  </section>

  <section>
    <h2>{content.sections.academic.educationTitle}</h2>
    <ul class="education-list">
      {education.map((item) => (
        <li>
          <span class="period">{item.period}</span>
          <div>
            <h3>{item.degree}</h3>
            <p class="institution">{item.institution}</p>
            {item.note && <p class="muted">{item.note}</p>}
            {item.tracks && (
              <ul class="track-list">
                {item.tracks.map((track) => (
                  <li>
                    <strong>{track.school}</strong> — {track.programme}.
                    <span class="muted"> {track.result}</span>
                  </li>
                ))}
              </ul>
            )}
            {item.courses && (
              <div class="courses">
                <p class="courses-label">{content.sections.academic.currentCoursesTitle}</p>
                <ul class="course-list">
                  {item.courses.map((course) => <li>{course}</li>)}
                </ul>
              </div>
            )}
          </div>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .topic-list,
  .track-list,
  .course-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .topic-list li {
    margin-bottom: 0.55rem;
  }

  .education-list {
    display: grid;
    gap: 1.6rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .education-list > li {
    display: grid;
    gap: 0.2rem;
    grid-template-columns: 7rem minmax(0, 1fr);
  }

  .period {
    color: var(--muted);
    font-size: 0.9rem;
    font-style: italic;
    padding-top: 0.15rem;
  }

  .institution {
    margin-bottom: 0.25rem;
  }

  .education-list p {
    margin-bottom: 0.2rem;
  }

  .track-list {
    margin: 0.4rem 0 0;
  }

  .track-list li {
    margin-bottom: 0.25rem;
  }

  .courses {
    margin-top: 0.8rem;
  }

  .courses-label {
    color: var(--muted);
    font-size: 0.82rem;
    font-style: italic;
    letter-spacing: 0.01em;
    margin: 0 0 0.35rem;
  }

  .course-list {
    column-count: 2;
    column-gap: 1.5rem;
    font-size: 0.97rem;
  }

  .course-list li {
    break-inside: avoid;
    padding: 0.05rem 0;
  }

  .course-list li::before {
    color: var(--muted);
    content: "·";
    display: inline-block;
    margin-right: 0.45rem;
  }

  @media (max-width: 640px) {
    .education-list > li {
      grid-template-columns: 1fr;
    }

    .course-list {
      column-count: 1;
    }
  }
</style>
