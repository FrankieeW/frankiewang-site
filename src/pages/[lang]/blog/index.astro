---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  formatDate,
  getLocale,
  localePath,
  locales,
  site,
} from "../../../data/site";
import { getPost, listPostSlugs } from "../../../lib/posts";
import { getPostLifecycle } from "../../../lib/postHistory";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = getLocale(Astro.params.lang);
const content = site[locale];

interface Entry {
  slug: string;
  title: string;
  text: string;
  topic: string;
  dateLabel: string;
}

const entries: Entry[] = [];
for (const slug of content.posts) {
  const post = getPost(slug, locale);
  if (!post) continue;
  const lifecycle = getPostLifecycle(slug);
  const iso = lifecycle?.publishedAt ?? null;
  entries.push({
    slug,
    title: post.title,
    text: post.text,
    topic: post.topic,
    dateLabel: iso ? formatDate(iso, locale) : post.topic,
  });
}

const _allSlugs = listPostSlugs();
---

<BaseLayout
  locale={locale}
  title={content.blogPage.title}
  description={content.blogPage.description}
>
  <section>
    <h1>{content.blogPage.heading}</h1>
    <p class="muted">{content.blogPage.lead}</p>
  </section>

  <section>
    {entries.length === 0 ? (
      <p class="muted todo">{content.blogPage.placeholder}</p>
    ) : (
      <ul class="entry-list">
        {entries.map((entry) => (
          <li>
            <span class="entry-meta">{entry.dateLabel}</span>
            <div>
              <h3>
                <a href={localePath(locale, `blog/${entry.slug}/`)}>{entry.title}</a>
              </h3>
              <p class="muted">{entry.text}</p>
            </div>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .entry-list {
    display: grid;
    gap: 1.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .entry-list li {
    display: grid;
    gap: 0.15rem;
    grid-template-columns: 9rem minmax(0, 1fr);
  }

  .entry-meta {
    color: var(--muted);
    font-size: 0.85rem;
    font-style: italic;
    padding-top: 0.15rem;
  }

  .entry-list h3 a {
    color: inherit;
  }

  .entry-list h3 a:hover {
    color: var(--link);
    text-decoration: none;
  }

  .entry-list p {
    margin-bottom: 0;
  }

  .todo {
    font-style: italic;
    margin: 0;
  }

  @media (max-width: 640px) {
    .entry-list li {
      grid-template-columns: 1fr;
    }
  }
</style>
