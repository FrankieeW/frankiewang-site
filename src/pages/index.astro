---
import ProductCard from "../components/ProductCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { academicHighlights, lifeHighlights, products, profile } from "../data/site";
---

<BaseLayout title={profile.name} description={profile.summary}>
  <section class="hero">
    <div class="hero-copy">
      <p class="section-kicker">Academic + life + products</p>
      <h1>{profile.name}</h1>
      <p class="lead">{profile.summary}</p>
      <div class="button-row">
        <a class="button" href="/products">View products</a>
        <a class="button secondary" href="#academic">Read academic work</a>
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <img
        src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=1400&q=80"
        alt=""
      />
      <div class="note">
        <strong>Current focus</strong>
        <span>formal methods, notes, and small software products</span>
      </div>
    </div>
  </section>

  <section id="academic">
    <p class="section-kicker">Academic</p>
    <h2>Research notes, formalization, and learning systems.</h2>
    <div class="grid three">
      {academicHighlights.map((item) => (
        <article class="card">
          <div class="card-body">
            <p class="pill">{item.label}</p>
            <h3>{item.title}</h3>
            <p class="muted">{item.text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="life" class="life-section">
    <div>
      <p class="section-kicker">Life</p>
      <h2>Personal fragments that keep the technical work human.</h2>
    </div>
    <ul>
      {lifeHighlights.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section>
    <div class="section-heading">
      <div>
        <p class="section-kicker">Products</p>
        <h2>Small products in progress.</h2>
      </div>
      <a class="button secondary" href="/products">All products</a>
    </div>
    <div class="grid three">
      {products.map((product) => <ProductCard product={product} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    align-items: end;
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    min-height: calc(100vh - 4.2rem);
    padding-top: 4rem;
  }

  .hero-copy {
    padding-bottom: 4rem;
  }

  .hero-visual {
    border: 1px solid var(--line);
    border-radius: 8px;
    min-height: 520px;
    overflow: hidden;
    position: relative;
  }

  .hero-visual img {
    height: 100%;
    min-height: 520px;
    object-fit: cover;
    width: 100%;
  }

  .note {
    background: rgba(251, 250, 246, 0.92);
    border: 1px solid rgba(222, 219, 210, 0.85);
    border-radius: 8px;
    bottom: 1rem;
    display: grid;
    gap: 0.25rem;
    left: 1rem;
    max-width: calc(100% - 2rem);
    padding: 0.9rem 1rem;
    position: absolute;
  }

  .note span {
    color: var(--muted);
  }

  .pill {
    color: var(--blue);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .life-section {
    align-items: start;
    border-bottom: 1px solid var(--line);
    border-top: 1px solid var(--line);
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(0, 0.9fr) minmax(280px, 0.7fr);
  }

  ul {
    display: grid;
    gap: 0.8rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li {
    background: var(--surface);
    border-left: 4px solid var(--gold);
    padding: 1rem;
  }

  .section-heading {
    align-items: end;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 900px) {
    .hero,
    .life-section {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
    }

    .hero-copy {
      padding-bottom: 0;
    }

    .section-heading {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
