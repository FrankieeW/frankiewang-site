---
import ProductCard from "../components/ProductCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { academicHighlights, lifeHighlights, products, profile, writing } from "../data/site";
---

<BaseLayout title={profile.name} description={profile.summary}>
  <section class="hero">
    <div>
      <p class="section-kicker">Academic / Life / Products</p>
      <h1>{profile.name}</h1>
      <p class="lead">{profile.title}</p>
    </div>
    <aside class="intro-note" aria-label="Current focus">
      <p>{profile.summary}</p>
      <p>{profile.current}</p>
      <div class="button-row">
        <a class="button" href="#research">Research</a>
        <a class="button secondary" href="/products">Products</a>
      </div>
    </aside>
  </section>

  <section id="research" class="split-section">
    <div>
      <p class="section-kicker">Research</p>
      <h2>Research notes, formalization, and learning systems.</h2>
    </div>
    <div class="stack-list">
      {academicHighlights.map((item) => (
        <article class="list-row">
          <span>{item.label}</span>
          <div>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="writing" class="split-section">
    <div>
      <p class="section-kicker">Writing</p>
      <h2>Essays, notes, and records of work in progress.</h2>
    </div>
    <div class="stack-list">
      {writing.map((item) => (
        <article class="list-row">
          <span>{item.meta}</span>
          <div>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="life" class="split-section">
    <div>
      <p class="section-kicker">Life</p>
      <h2>Personal fragments that keep the technical work human.</h2>
    </div>
    <ul class="life-list">
      {lifeHighlights.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="products-section">
    <div class="section-heading">
      <p class="section-kicker">Products</p>
      <h2>Small products in progress.</h2>
      <a class="button secondary" href="/products">All products</a>
    </div>
    <div class="grid three">
      {products.map((product) => <ProductCard product={product} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    align-items: start;
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.52fr);
    min-height: 72vh;
    padding-top: 7rem;
  }

  .intro-note {
    border-left: 1px solid var(--line-strong);
    color: var(--muted);
    padding-left: 1.5rem;
  }

  .intro-note p {
    margin-bottom: 1rem;
  }

  .split-section {
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(0, 0.72fr) minmax(280px, 1fr);
  }

  .stack-list {
    display: grid;
    gap: 1.4rem;
  }

  .list-row {
    border-top: 1px solid var(--line);
    display: grid;
    gap: 1rem;
    grid-template-columns: 5.5rem minmax(0, 1fr);
    padding-top: 1rem;
  }

  .list-row > span {
    color: var(--accent);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .list-row p {
    color: var(--muted);
    margin-bottom: 0;
  }

  .life-list {
    display: grid;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .life-list li {
    border-top: 1px solid var(--line);
    color: var(--muted);
    padding-top: 1rem;
  }

  .products-section {
    padding-bottom: 2rem;
  }

  .section-heading {
    align-items: start;
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 0.25fr) minmax(0, 1fr) auto;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 900px) {
    .hero,
    .split-section,
    .section-heading {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
    }

    .intro-note {
      border-left: 0;
      border-top: 1px solid var(--line-strong);
      padding-left: 0;
      padding-top: 1.25rem;
    }

    .list-row {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
  }
</style>
