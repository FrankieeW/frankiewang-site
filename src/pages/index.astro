---
import ProductCard from "../components/ProductCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  academicHighlights,
  indexLinks,
  lifeHighlights,
  products,
  profile,
  writing,
} from "../data/site";
---

<BaseLayout title={profile.name} description={profile.summary}>
  <section class="hero">
    <div>
      <p class="section-kicker">Pure Mathematics</p>
      <h1>{profile.name}</h1>
      <p class="lead">{profile.title}</p>
    </div>
    <aside class="intro-note" aria-label="Current focus">
      <p>{profile.summary}</p>
      <p>{profile.current}</p>
      <dl class="affiliation-list">
        <div>
          <dt>Programme</dt>
          <dd>MSc Pure Mathematics</dd>
        </div>
        <div>
          <dt>Department</dt>
          <dd><a href={profile.departmentUrl}>{profile.department}</a></dd>
        </div>
        <div>
          <dt>Research group</dt>
          <dd><a href={profile.groupUrl}>Pure Mathematics</a></dd>
        </div>
      </dl>
    </aside>
  </section>

  <section class="index-panel" aria-label="Site index">
    <p class="section-kicker">Index</p>
    <nav class="index-links" aria-label="Section links">
      {indexLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
  </section>

  <section id="research" class="split-section">
    <div>
      <p class="section-kicker">Research</p>
      <h2>Research interests, formalization, and mathematical notes.</h2>
    </div>
    <div class="stack-list">
      {academicHighlights.map((item) => (
        <article class="list-row">
          <span>{item.label}</span>
          <div>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="writing" class="split-section">
    <div>
      <p class="section-kicker">Writing</p>
      <h2>Essays, notes, and records of work in progress.</h2>
    </div>
    <div class="stack-list">
      {writing.map((item) => (
        <article class="list-row">
          <span>{item.meta}</span>
          <div>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="life" class="split-section">
    <div>
      <p class="section-kicker">Life</p>
      <h2>Personal fragments that keep the technical work human.</h2>
    </div>
    <ul class="life-list">
      {lifeHighlights.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="products-section">
    <div class="section-heading">
      <p class="section-kicker">Projects</p>
      <h2>Small tools and projects in progress.</h2>
      <a class="button secondary" href="/products">All projects</a>
    </div>
    <div class="grid three">
      {products.map((product) => <ProductCard product={product} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    align-items: start;
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.52fr);
    min-height: 72vh;
    padding-top: 7rem;
  }

  .intro-note {
    border-left: 1px solid var(--line-strong);
    color: var(--muted);
    padding-left: 1.5rem;
  }

  .intro-note p {
    margin-bottom: 1rem;
  }

  .affiliation-list {
    border-top: 2px solid var(--imperial-blue);
    display: grid;
    gap: 0;
    margin: 1.4rem 0 0;
  }

  .affiliation-list div {
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 0.4rem;
    grid-template-columns: 7rem minmax(0, 1fr);
    padding: 0.75rem 0;
  }

  dt {
    color: var(--accent);
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  dd {
    margin: 0;
  }

  dd a {
    border-bottom: 1px solid var(--line-strong);
  }

  .index-panel {
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 1rem;
    grid-template-columns: 7rem minmax(0, 1fr);
    padding-bottom: 2.25rem;
    padding-top: 2.25rem;
  }

  .index-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .index-links a {
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    color: var(--ink);
    font-size: 0.92rem;
    min-height: 2.35rem;
    padding: 0.52rem 0.85rem;
  }

  .index-links a:hover {
    border-color: var(--imperial-blue);
    color: var(--imperial-blue);
  }

  .split-section {
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(0, 0.72fr) minmax(280px, 1fr);
  }

  .stack-list {
    display: grid;
    gap: 1.4rem;
  }

  .list-row {
    border-top: 1px solid var(--line);
    display: grid;
    gap: 1rem;
    grid-template-columns: 5.5rem minmax(0, 1fr);
    padding-top: 1rem;
  }

  .list-row > span {
    color: var(--accent);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .list-row p {
    color: var(--muted);
    margin-bottom: 0;
  }

  .life-list {
    display: grid;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .life-list li {
    border-top: 1px solid var(--line);
    color: var(--muted);
    padding-top: 1rem;
  }

  .products-section {
    padding-bottom: 2rem;
  }

  .section-heading {
    align-items: start;
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 0.25fr) minmax(0, 1fr) auto;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 900px) {
    .hero,
    .split-section,
    .section-heading {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
    }

    .intro-note {
      border-left: 0;
      border-top: 1px solid var(--line-strong);
      padding-left: 0;
      padding-top: 1.25rem;
    }

    .list-row {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }

    .index-panel,
    .affiliation-list div {
      grid-template-columns: 1fr;
    }
  }
</style>
