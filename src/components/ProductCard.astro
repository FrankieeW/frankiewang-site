---
interface Product {
  slug: string;
  name: string;
  eyebrow: string;
  tagline: string;
  status: string;
  image: string;
}

const { product } = Astro.props as { product: Product };
---

<article class="card product-card">
  <a href={`/products/${product.slug}/`} aria-label={`Open ${product.name}`}>
    <img src={product.image} alt="" loading="lazy" />
    <div class="card-body">
      <div class="product-meta">
        <span>{product.eyebrow}</span>
        <span>{product.status}</span>
      </div>
      <h3>{product.name}</h3>
      <p class="muted">{product.tagline}</p>
    </div>
  </a>
</article>

<style>
  .product-card a {
    display: block;
    height: 100%;
  }

  img {
    aspect-ratio: 16 / 10;
    height: auto;
    object-fit: cover;
    width: 100%;
  }

  .product-meta {
    color: var(--brick);
    display: flex;
    font-size: 0.78rem;
    font-weight: 800;
    justify-content: space-between;
    letter-spacing: 0.06em;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  h3 {
    margin-bottom: 0.55rem;
  }

  p {
    margin-bottom: 0;
  }
</style>
