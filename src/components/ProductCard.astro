---
interface Product {
  slug: string;
  name: string;
  eyebrow: string;
  tagline: string;
  status: string;
}

const { product } = Astro.props as { product: Product };
---

<article class="card product-card">
  <a href={`/products/${product.slug}/`} aria-label={`Open ${product.name}`}>
    <div class="card-body">
      <div class="product-meta">
        <span>{product.eyebrow}</span>
        <span>{product.status}</span>
      </div>
      <h3>{product.name}</h3>
      <p class="muted">{product.tagline}</p>
    </div>
  </a>
</article>

<style>
  .product-card a {
    display: block;
    height: 100%;
  }

  .product-meta {
    color: var(--accent);
    display: flex;
    font-size: 0.78rem;
    font-weight: 650;
    justify-content: space-between;
    letter-spacing: 0.08em;
    margin-bottom: 0.9rem;
    text-transform: uppercase;
  }

  h3 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.35rem;
    font-weight: 500;
    margin-bottom: 0.6rem;
  }

  p {
    margin-bottom: 0;
  }
</style>
