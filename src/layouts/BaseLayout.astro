---
import { profile } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = profile.name,
  description = profile.summary,
} = Astro.props;

const pageTitle = title === profile.name ? title : `${title} | ${profile.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="institution-strip" aria-label="Academic affiliation">
      <span>{profile.institution}</span>
      <span>{profile.department}</span>
    </div>
    <header class="site-header">
      <a class="brand" href="/" aria-label={`${profile.name} home`}>
        <span class="brand-mark">FW</span>
        <span>{profile.name}</span>
      </a>
      <nav aria-label="Primary navigation">
        <a href="/#research">Research</a>
        <a href="/#writing">Writing</a>
        <a href="/#life">Life</a>
        <a href="/products">Projects</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>Independent personal website</span>
      <a href={profile.github}>GitHub</a>
      <a href={`mailto:${profile.email}`}>{profile.email}</a>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #171717;
    --muted: #66645f;
    --paper: #faf9f5;
    --surface: #ffffff;
    --line: #dfddd5;
    --line-strong: #c8c5bb;
    --accent: #7a3f2b;
    --imperial-blue: #003e74;
    --blue: #355c7d;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    line-height: 1.6;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .institution-strip,
  .site-header,
  .site-footer {
    align-items: center;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    margin: 0 auto;
    max-width: 1040px;
    padding: 1.1rem 1.25rem;
  }

  .institution-strip {
    background: var(--imperial-blue);
    color: #ffffff;
    font-size: 0.78rem;
    font-weight: 620;
    letter-spacing: 0.02em;
    padding-bottom: 0.55rem;
    padding-top: 0.55rem;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
    background: rgba(250, 249, 245, 0.88);
    border-bottom: 1px solid rgba(223, 221, 213, 0.82);
  }

  .brand,
  nav,
  .site-footer {
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 520;
  }

  .brand {
    align-items: center;
    color: var(--ink);
    display: inline-flex;
    gap: 0.65rem;
    white-space: nowrap;
  }

  .brand-mark {
    align-items: center;
    border: 1px solid var(--line-strong);
    border-radius: 50%;
    color: var(--ink);
    display: inline-flex;
    font-size: 0.78rem;
    height: 2.1rem;
    justify-content: center;
    width: 2.1rem;
  }

  nav {
    display: flex;
    gap: 1rem;
  }

  nav a,
  .site-footer a {
    border-bottom: 1px solid transparent;
  }

  nav a:hover,
  .site-footer a:hover {
    border-color: currentColor;
    color: var(--ink);
  }

  section,
  .page-shell {
    margin: 0 auto;
    max-width: 1040px;
    padding: 4.75rem 1.25rem;
  }

  .section-kicker {
    color: var(--accent);
    font-size: 0.76rem;
    font-weight: 650;
    letter-spacing: 0.12em;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3.1rem, 8vw, 6.4rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 0.98;
    margin-bottom: 1.25rem;
    max-width: 860px;
  }

  h2 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.9rem, 4vw, 3.2rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.08;
    margin-bottom: 1rem;
    max-width: 780px;
  }

  h3 {
    font-size: 1rem;
    line-height: 1.35;
    margin-bottom: 0.4rem;
  }

  .lead {
    color: var(--muted);
    font-size: clamp(1.1rem, 2vw, 1.28rem);
    max-width: 700px;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .button {
    align-items: center;
    background: transparent;
    border: 1px solid var(--ink);
    border-radius: 999px;
    color: var(--ink);
    display: inline-flex;
    font-size: 0.92rem;
    font-weight: 620;
    min-height: 2.65rem;
    padding: 0.65rem 1rem;
  }

  .button.secondary {
    border-color: var(--line-strong);
    color: var(--muted);
  }

  .grid {
    display: grid;
    gap: 1rem;
  }

  .grid.three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .card {
    border-top: 1px solid var(--line);
    padding-top: 1rem;
  }

  .card-body {
    padding: 0;
  }

  .muted {
    color: var(--muted);
  }

  .site-footer {
    border-top: 1px solid var(--line);
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  @media (max-width: 760px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .institution-strip {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.25rem;
    }

    nav {
      flex-wrap: wrap;
    }

    section,
    .page-shell {
      padding: 3.5rem 1rem;
    }

    .grid.three {
      grid-template-columns: 1fr;
    }
  }
</style>
