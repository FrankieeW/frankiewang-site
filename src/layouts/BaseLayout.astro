---
import { localeLabels, locales, localePath, site, type Locale } from "../data/site";

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const {
  locale,
  title,
  description,
} = Astro.props;

const content = site[locale];
const profile = content.profile;
const pageTitle = !title || title === profile.name ? profile.name : `${title} | ${profile.name}`;
const pageDescription = description ?? profile.summary;
const suffix = Astro.url.pathname.replace(/^\/(en|zh|fr)/, "") || "/";
---

<!doctype html>
<html lang={content.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={localePath(locale)} aria-label={`${profile.name} home`}>
        {profile.name}
      </a>
      <nav aria-label="Primary navigation">
        <a href={localePath(locale, "academic/")}>{content.nav.academic}</a>
        <a href={localePath(locale, "notes/")}>{content.nav.notes}</a>
        <a href={localePath(locale, "products/")}>{content.nav.projects}</a>
        <a href={`${localePath(locale)}#contact`}>{content.nav.contact}</a>
      </nav>
      <div class="language-switch" aria-label="Language switcher">
        {locales.map((code) => (
          <a class:list={{ active: code === locale }} href={`/${code}${suffix}`}>
            {localeLabels[code]}
          </a>
        ))}
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>{content.footer}</span>
      <a href={profile.github}>GitHub</a>
      <a href={`mailto:${profile.email}`}>{profile.email}</a>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #1a1a1a;
    --muted: #5c5c5c;
    --paper: #fdfcf8;
    --surface: #ffffff;
    --line: #e5e2d8;
    --line-strong: #c8c5bb;
    --accent: #8a4a2a;
    --link: #1a4a7a;
    font-family:
      "Source Serif Pro", "Iowan Old Style", "Palatino Linotype", Palatino, Georgia,
      "Times New Roman", serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    font-size: 17px;
    line-height: 1.65;
  }

  a {
    color: var(--link);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .site-header,
  .site-footer {
    align-items: baseline;
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    justify-content: space-between;
    margin: 0 auto;
    max-width: 760px;
    padding: 1.4rem 1.5rem 0.9rem;
  }

  .site-header {
    border-bottom: 1px solid var(--line);
  }

  .brand {
    color: var(--ink);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .brand:hover {
    text-decoration: none;
  }

  nav {
    color: var(--muted);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.95rem;
    gap: 1.1rem;
  }

  nav a {
    color: var(--muted);
  }

  nav a:hover {
    color: var(--ink);
    text-decoration: none;
  }

  .language-switch {
    color: var(--muted);
    display: flex;
    font-size: 0.85rem;
    gap: 0.5rem;
  }

  .language-switch a {
    color: var(--muted);
  }

  .language-switch a.active {
    color: var(--ink);
    font-weight: 600;
    text-decoration: none;
  }

  main {
    margin: 0 auto;
    max-width: 760px;
    padding: 0 1.5rem;
  }

  section,
  .page-shell {
    margin: 0;
    max-width: none;
    padding: 2.25rem 0;
  }

  section + section {
    border-top: 1px solid var(--line);
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    font-size: 1.8rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.25;
    margin-bottom: 0.9rem;
  }

  h3 {
    font-size: 1.02rem;
    font-weight: 600;
    line-height: 1.35;
    margin-bottom: 0.25rem;
  }

  p {
    margin-bottom: 0.9rem;
  }

  .lead {
    color: var(--ink);
    font-size: 1.02rem;
  }

  .muted {
    color: var(--muted);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .button {
    color: var(--link);
    display: inline-block;
    font-size: 0.95rem;
  }

  .button.secondary {
    color: var(--muted);
  }

  .grid {
    display: grid;
    gap: 1rem;
  }

  .grid.three {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .card {
    padding: 0;
  }

  .card-body {
    padding: 0;
  }

  .site-footer {
    border-bottom: 0;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.9rem;
    margin-top: 3rem;
    padding-bottom: 1.4rem;
    padding-top: 0.9rem;
  }

  .site-footer a {
    color: var(--muted);
  }

  @media (max-width: 640px) {
    body {
      font-size: 16px;
    }

    .site-header,
    .site-footer {
      gap: 0.6rem;
    }

    .grid.three {
      grid-template-columns: 1fr;
    }
  }
</style>
