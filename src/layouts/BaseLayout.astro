---
import { profile } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = profile.name,
  description = profile.summary,
} = Astro.props;

const pageTitle = title === profile.name ? title : `${title} | ${profile.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label={`${profile.name} home`}>
        <span class="brand-mark">FW</span>
        <span>{profile.name}</span>
      </a>
      <nav aria-label="Primary navigation">
        <a href="/#academic">Academic</a>
        <a href="/#life">Life</a>
        <a href="/products">Products</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>{profile.location}</span>
      <a href={profile.github}>GitHub</a>
      <a href={`mailto:${profile.email}`}>{profile.email}</a>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #202321;
    --muted: #626861;
    --paper: #fbfaf6;
    --surface: #ffffff;
    --line: #dedbd2;
    --pine: #1f5c4d;
    --brick: #a24835;
    --blue: #2e5e88;
    --gold: #c59a3d;
    --shadow: 0 18px 50px rgba(32, 35, 33, 0.1);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    line-height: 1.55;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .site-header,
  .site-footer {
    align-items: center;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    margin: 0 auto;
    max-width: 1180px;
    padding: 1rem 1.25rem;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
    background: rgba(251, 250, 246, 0.84);
    border-bottom: 1px solid rgba(222, 219, 210, 0.7);
  }

  .brand,
  nav,
  .site-footer {
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 650;
  }

  .brand {
    align-items: center;
    color: var(--ink);
    display: inline-flex;
    gap: 0.65rem;
    white-space: nowrap;
  }

  .brand-mark {
    align-items: center;
    background: var(--ink);
    border-radius: 50%;
    color: var(--paper);
    display: inline-flex;
    font-size: 0.78rem;
    height: 2.1rem;
    justify-content: center;
    width: 2.1rem;
  }

  nav {
    display: flex;
    gap: 1rem;
  }

  nav a,
  .site-footer a {
    border-bottom: 1px solid transparent;
  }

  nav a:hover,
  .site-footer a:hover {
    border-color: currentColor;
    color: var(--ink);
  }

  section,
  .page-shell {
    margin: 0 auto;
    max-width: 1180px;
    padding: 5rem 1.25rem;
  }

  .section-kicker {
    color: var(--brick);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    font-size: clamp(3rem, 8vw, 6.8rem);
    letter-spacing: 0;
    line-height: 0.95;
    margin-bottom: 1.25rem;
    max-width: 940px;
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3.4rem);
    letter-spacing: 0;
    line-height: 1.02;
    margin-bottom: 1rem;
    max-width: 820px;
  }

  h3 {
    font-size: 1.15rem;
    line-height: 1.2;
  }

  .lead {
    color: var(--muted);
    font-size: clamp(1.08rem, 2vw, 1.35rem);
    max-width: 760px;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .button {
    align-items: center;
    background: var(--ink);
    border: 1px solid var(--ink);
    border-radius: 999px;
    color: var(--paper);
    display: inline-flex;
    font-weight: 750;
    min-height: 2.8rem;
    padding: 0.72rem 1.1rem;
  }

  .button.secondary {
    background: transparent;
    color: var(--ink);
  }

  .grid {
    display: grid;
    gap: 1rem;
  }

  .grid.three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .card-body {
    padding: 1.25rem;
  }

  .muted {
    color: var(--muted);
  }

  .site-footer {
    border-top: 1px solid var(--line);
    flex-wrap: wrap;
    margin-top: 3rem;
  }

  @media (max-width: 760px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    nav {
      flex-wrap: wrap;
    }

    section,
    .page-shell {
      padding: 3.5rem 1rem;
    }

    .grid.three {
      grid-template-columns: 1fr;
    }
  }
</style>
